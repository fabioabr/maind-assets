{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Maind Tech — Color Tokens v1. Extracted from brand reference (Robo3.png).",
  "color": {
    "cyan": {
      "$description": "Electric Cyan — primary brand accent. Logo glow, eyes, contour highlights.",
      "50":  { "$value": "#E5F8FF", "$type": "color" },
      "100": { "$value": "#CCF1FF", "$type": "color" },
      "200": { "$value": "#99E3FF", "$type": "color" },
      "300": { "$value": "#66D4FF", "$type": "color" },
      "400": { "$value": "#33C6FF", "$type": "color" },
      "500": { "$value": "#00C8FF", "$type": "color", "$description": "Base — Electric Cyan" },
      "600": { "$value": "#1E9CFF", "$type": "color" },
      "700": { "$value": "#0077CC", "$type": "color" },
      "800": { "$value": "#005C99", "$type": "color" },
      "900": { "$value": "#003D66", "$type": "color" }
    },
    "violet": {
      "$description": "Royal Violet — secondary brand. Ambient lighting and depth.",
      "50":  { "$value": "#F3EEFF", "$type": "color" },
      "100": { "$value": "#E5DBFF", "$type": "color" },
      "200": { "$value": "#CBB7FF", "$type": "color" },
      "300": { "$value": "#B093FF", "$type": "color" },
      "400": { "$value": "#9670EE", "$type": "color" },
      "500": { "$value": "#8B5CF6", "$type": "color", "$description": "Base — Royal Violet" },
      "600": { "$value": "#6B3FA0", "$type": "color" },
      "700": { "$value": "#553080", "$type": "color" },
      "800": { "$value": "#3F2360", "$type": "color" },
      "900": { "$value": "#2A1740", "$type": "color" }
    },
    "magenta": {
      "$description": "Neon Magenta — accent for highlights, gradient endpoints, attention.",
      "50":  { "$value": "#FDF0FF", "$type": "color" },
      "100": { "$value": "#FBE0FF", "$type": "color" },
      "200": { "$value": "#F7C2FF", "$type": "color" },
      "300": { "$value": "#F0A0FA", "$type": "color" },
      "400": { "$value": "#E879F9", "$type": "color" },
      "500": { "$value": "#D946EF", "$type": "color", "$description": "Base — Neon Magenta" },
      "600": { "$value": "#B91FCF", "$type": "color" },
      "700": { "$value": "#8E1AA0", "$type": "color" },
      "800": { "$value": "#661274", "$type": "color" },
      "900": { "$value": "#3F0A48", "$type": "color" }
    },
    "indigo": {
      "$description": "Midnight Indigo — primary background and deep surfaces.",
      "50":  { "$value": "#ECEAF5", "$type": "color" },
      "100": { "$value": "#D4D0E8", "$type": "color" },
      "200": { "$value": "#A9A1D1", "$type": "color" },
      "300": { "$value": "#7E72BA", "$type": "color" },
      "400": { "$value": "#5343A3", "$type": "color" },
      "500": { "$value": "#2A1B4E", "$type": "color", "$description": "Base — Midnight Indigo" },
      "600": { "$value": "#1F1339", "$type": "color" },
      "700": { "$value": "#1A1240", "$type": "color", "$description": "Deep background" },
      "800": { "$value": "#100A28", "$type": "color" },
      "900": { "$value": "#080517", "$type": "color" }
    },
    "neutral": {
      "$description": "Cloud → Obsidian — surfaces, text, borders.",
      "0":   { "$value": "#FFFFFF", "$type": "color" },
      "50":  { "$value": "#F5F6FA", "$type": "color", "$description": "Cloud White (robot body)" },
      "100": { "$value": "#E8EAF0", "$type": "color" },
      "200": { "$value": "#D1D5E0", "$type": "color" },
      "300": { "$value": "#9BA1B5", "$type": "color" },
      "400": { "$value": "#6B7185", "$type": "color" },
      "500": { "$value": "#4A4F60", "$type": "color" },
      "600": { "$value": "#2E323F", "$type": "color" },
      "700": { "$value": "#1A1F2E", "$type": "color" },
      "800": { "$value": "#0A0E1A", "$type": "color", "$description": "Obsidian (screen black)" },
      "900": { "$value": "#000000", "$type": "color" }
    },
    "blush": {
      "$description": "Soft pink blush — used sparingly for warmth (cheeks accent).",
      "500": { "$value": "#FFA8C5", "$type": "color" }
    }
  },
  "theme": {
    "light": {
      "$description": "Light theme semantic mapping — default on :root.",
      "background": {
        "primary":   { "$value": "{color.neutral.0}",   "$type": "color" },
        "secondary": { "$value": "{color.neutral.50}",  "$type": "color" },
        "elevated":  { "$value": "{color.neutral.0}",   "$type": "color" }
      },
      "surface": {
        "default":  { "$value": "{color.neutral.0}",   "$type": "color" },
        "raised":   { "$value": "{color.neutral.50}",  "$type": "color" },
        "inverted": { "$value": "{color.indigo.700}",  "$type": "color" }
      },
      "text": {
        "primary":   { "$value": "{color.indigo.800}", "$type": "color" },
        "secondary": { "$value": "{color.neutral.600}","$type": "color" },
        "muted":     { "$value": "{color.neutral.400}","$type": "color" },
        "inverted":  { "$value": "{color.neutral.50}", "$type": "color" },
        "accent":    { "$value": "{color.cyan.700}",   "$type": "color", "$description": "Cyan-700 for AA contrast on white." },
        "onBrand":   { "$value": "{color.indigo.800}", "$type": "color", "$description": "Text over cyan/violet/magenta solids." }
      },
      "border": {
        "subtle":  { "$value": "{color.neutral.100}", "$type": "color" },
        "default": { "$value": "{color.neutral.200}", "$type": "color" },
        "strong":  { "$value": "{color.cyan.600}",   "$type": "color" }
      },
      "action": {
        "primary":         { "$value": "{color.cyan.500}",   "$type": "color" },
        "primaryHover":    { "$value": "{color.cyan.600}",   "$type": "color" },
        "primaryText":     { "$value": "{color.indigo.800}", "$type": "color" },
        "secondary":       { "$value": "{color.violet.500}", "$type": "color" },
        "secondaryHover":  { "$value": "{color.violet.600}", "$type": "color" },
        "secondaryText":   { "$value": "{color.neutral.0}",  "$type": "color" },
        "accent":          { "$value": "{color.magenta.500}","$type": "color" },
        "accentHover":     { "$value": "{color.magenta.600}","$type": "color" },
        "accentText":      { "$value": "{color.neutral.0}",  "$type": "color" }
      }
    },
    "dark": {
      "$description": "Dark theme semantic mapping — applied via [data-theme=\"dark\"]. Deeper hierarchy 900 → 800 → 700.",
      "background": {
        "primary":   { "$value": "{color.indigo.900}", "$type": "color" },
        "secondary": { "$value": "{color.indigo.700}", "$type": "color" },
        "elevated":  { "$value": "{color.indigo.800}", "$type": "color" }
      },
      "surface": {
        "default":  { "$value": "{color.indigo.800}", "$type": "color" },
        "raised":   { "$value": "{color.violet.900}", "$type": "color" },
        "inverted": { "$value": "{color.neutral.50}",  "$type": "color" }
      },
      "text": {
        "primary":   { "$value": "{color.neutral.50}",  "$type": "color" },
        "secondary": { "$value": "{color.neutral.200}", "$type": "color" },
        "muted":     { "$value": "{color.neutral.300}", "$type": "color" },
        "inverted":  { "$value": "{color.indigo.800}",  "$type": "color" },
        "accent":    { "$value": "{color.cyan.500}",    "$type": "color" },
        "onBrand":   { "$value": "{color.indigo.800}",  "$type": "color" }
      },
      "border": {
        "subtle":  { "$value": "{color.violet.900}", "$type": "color" },
        "default": { "$value": "{color.violet.800}", "$type": "color" },
        "strong":  { "$value": "{color.cyan.500}",   "$type": "color" }
      },
      "action": {
        "primary":         { "$value": "{color.cyan.500}",   "$type": "color" },
        "primaryHover":    { "$value": "{color.cyan.400}",   "$type": "color" },
        "primaryText":     { "$value": "{color.indigo.800}", "$type": "color" },
        "secondary":       { "$value": "{color.violet.500}", "$type": "color" },
        "secondaryHover":  { "$value": "{color.violet.400}", "$type": "color" },
        "secondaryText":   { "$value": "{color.neutral.0}",  "$type": "color" },
        "accent":          { "$value": "{color.magenta.500}","$type": "color" },
        "accentHover":     { "$value": "{color.magenta.400}","$type": "color" },
        "accentText":      { "$value": "{color.neutral.0}",  "$type": "color" }
      }
    }
  },
  "gradient": {
    "brand":     { "$value": "linear-gradient(135deg, #8B5CF6 0%, #00C8FF 100%)", "$type": "gradient", "$description": "Violet → Cyan (signature brand gradient)" },
    "neon":      { "$value": "linear-gradient(135deg, #D946EF 0%, #00C8FF 100%)", "$type": "gradient", "$description": "Magenta → Cyan (high-energy accent)" },
    "ambient":   { "$value": "linear-gradient(135deg, #2A1740 0%, #1A1240 50%, #0A0E1A 100%)", "$type": "gradient", "$description": "Background depth (matches scene lighting)" },
    "halo":      { "$value": "radial-gradient(circle at 30% 30%, #8B5CF6 0%, #1A1240 60%, #080517 100%)", "$type": "gradient", "$description": "Violet halo glow on dark backdrop" }
  }
}
